{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "lint:security": "eslint --no-warn-ignored 'src/**/*.{ts,tsx}'",
    "typecheck": "tsc --noEmit",
    "audit:deps": "pnpm audit --prod --audit-level=moderate",
    "audit:secrets": "gitleaks detect --source=. --no-banner --redact",
    "audit:semgrep": "semgrep --config=p/owasp-top-ten --config=p/javascript --config=p/typescript --config=p/nextjs --config=p/react --config=p/jwt --config=p/secrets --metrics=off --severity ERROR --severity WARNING --error src/",
    "audit:all": "pnpm audit:deps && pnpm audit:secrets && pnpm audit:semgrep && pnpm typecheck && pnpm lint:security",
    "security:report": "bash scripts/security-report.sh"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.53.1",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.2.1",
    "framer-motion": "^12.39.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.16.0",
    "nanoid": "^5.1.11",
    "next": "15.5.18",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.76.0",
    "react-signature-canvas": "1.1.0-alpha.2",
    "sonner": "^2.0.7",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "eslint-plugin-security": "^3.0.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "pnpm": {
    "overrides": {
      "postcss": "^8.5.10"
    }
  }
}
